#!/bin/bash

#SBATCH -J DIRtest

##  partition (queue)
#SBATCH --account=bltp
#SBATCH --partition=bltp
#SBATCH --constraint=cascade
#SBATCH --qos=short
## max. execution time
#SBATCH -t 0-04:00:00

##SBATCH --mem=128GB
#SBATCH --mem=32GB

# do not restart in the case of nodefail!
#SBATCH --no-requeue
#SBATCH --no-kill

#SBATCH -N 1 -n 4
##SBATCH --ntasks-per-node=12

##SBATCH  --sockets-per-node=1

## memory NO !!!
##SBATCH --mem-per-cpu=28G

## stdout/stderr output file
##SBATCH -o log_slurm_job.%j.%N.std_out_err
#SBATCH -o log_slurm_job.%j.%N.std_out

## mail
#SBATCH --mail-user=milias@jinr.ru
#SBATCH --mail-type=ALL

echo -e "\nRunning on host `hostname`"
echo -e "Time is `date` \n"
ulimit -s unlimited

echo -e "\n The total memory at the node (in GB)"
free -t -g
echo -e "\n"
 
echo Job user is $SLURM_JOB_USER and his job $SLURM_JOB_NAME has assigned ID $SLURM_JOBID
echo This job was submitted from the computer $SLURM_SUBMIT_HOST
echo and from the home directory:
echo $SLURM_SUBMIT_DIR
echo
echo It is running on the cluster compute node:
echo $SLURM_CLUSTER_NAME
echo and is employing $SLURM_JOB_NUM_NODES node/nodes:
echo $SLURM_JOB_NODELIST
echo
echo -e "Job partition is $SLURM_JOB_PARTITION \n"
echo The job requests $SLURM_CPUS_ON_NODE CPU per task.

# CPU model, total numer of CPUs, number of allocated CPUs
echo -e "The node's CPU \c"; cat /proc/cpuinfo | grep 'model name' | uniq
NPROCS=`cat /proc/cpuinfo | grep processor | wc -l`
echo "This node has total NPROCS=$NPROCS CPUs available for an EXCLUSIVE job."
echo "Based on reserved memory, this node got SLURM_CPUS_ON_NODE=$SLURM_CPUS_ON_NODE CPUs allocated for SLURM calculations."
echo "This job wants SLURM_NTASKS=$SLURM_NTASKS threads . "


#MACHINEFILE="nodes.$SLURM_JOB_PARTITION.$SLURM_JOB_ID"
# Generate Machinefile for mpi such that hosts are in the same
# order as if run via srun
#srun -l /bin/hostname | sort -n | awk '{print $2}' > $MACHINEFILE
echo -e "\n Allocated working nodes:"
srun -l /bin/hostname | sort -n | awk '{print $2}' 
#echo -e "\ngenerated machinefile for MPI, $MACHINEFILE"; ls -lt $PWD/$MACHINEFILE; echo "containing:"; cat $MACHINEFILE

echo -e "\n\n loaded modules:"
module purge
#module add GVR/v1.0-1
module add Python/v3.12.13
module add CMake/v4.2.3
#module add  intel/v2025.3.1
module add  intel/v2023.1.0
#module add openmpi/v5.0.3_gcc1230
#module add LAPACK/v3.12.0_gcc1230
module list

echo -e "\n python ? :\c"; which python; python -V
echo -e "  cmake ? :\c";  which cmake; cmake --version
echo -e "  mpiifort ? :\c"; which mpiifort; mpiifort -V
echo -e "  mpiicc ? :\c"; which mpiicc; mpiicc -V
echo -e "  mpiicpc ? :\c"; which mpiicpc; mpiicpc  -V
echo -e "  mpirun ? :\c"; which mpirun; mpirun --version
echo -e "\n Intel MKL library ? MKLROOT=$MKLROOT"; ls -lt  $MKLROOT/lib/intel64

echo -e "\n The variable PATH=$PATH\n"
echo -e "\n The variable HOME=$HOME\n"

echo -e "\n content of $HOME/.diracrc :"
cat $HOME/.diracrc

#DIRAC=/lustre/home/user/m/milias/work/software/dirac/trunk
#DIRAC=/zfs/store5.hydra.local/user/m/milias/work/software/dirac/trunk_cloned
DIRAC=/lustre/projects/m/milias/work/software/dirac/trunk_cloned
#BUILD=build_intelmpi2025_mkl_i8
BUILD=build_intelmpi2023_mkl_i8

echo -e "\n ldd $DIRAC/$BUILD/dirac.x:"
ldd $DIRAC/$BUILD/dirac.x

echo -e "\n checking pam script, $DIRAC/$BUILD/pam --help  :"
$DIRAC/$BUILD/pam --help

export DIRAC_TMPDIR=/lustre/projects/m/milias/DIRAC_scratch
echo -e "\n DIRAC_TMPDIR=$DIRAC_TMPDIR"

echo -e "\n\n         I am in pwd=\c";pwd
echo -e "This is SLURM_SUBMIT_DIR=$SLURM_SUBMIT_DIR"

export DIRAC_MPI_COMMAND="mpirun -f $SLURM_SUBMIT_DIR/$MACHINEFILE -np $SLURM_NTASKS"
echo -e "\n DIRAC_MPI_COMMAND=$DIRAC_MPI_COMMAND"
out_suffix=out.$SLURM_CLUSTER_NAME.$SLURM_JOB_PARTITION.N$SLURM_JOB_NUM_NODES.n$SLURM_NTASKS.jid$SLURM_JOBID.out

testdir=cc_essential
inpf=ccsd.small.inp
molf=H2O.mol

echo -e "\n\nRunning job from DIRAC test directory: $DIRAC/test/$testdir"
echo -e "DIRAC input file=$inpf ; DIRAC mol file=$molf"
echo -e "suffix for the DIRAC output file = $out_suffix\n\n"

#$DIRAC/$BUILD/pam --noarch --inp=$DIRAC/test/benchmark_cc/cc.inp --mol=$DIRAC/test/benchmark_cc/C2H4Cl2_ec1_c2.mol --suffix=$out_suffix
$DIRAC/$BUILD/pam --noarch --mw=64 --aw=130 --inp=$DIRAC/test/$testdir/$inpf --mol=$DIRAC/test/$testdir/$molf --suffix=$out_suffix


exit
