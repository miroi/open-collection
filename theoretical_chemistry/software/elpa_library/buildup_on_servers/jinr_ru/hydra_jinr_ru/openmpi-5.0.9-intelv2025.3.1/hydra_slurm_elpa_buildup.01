#!/bin/bash

#SBATCH -J elpaOMPI

##  partition (queue)
#SBATCH --account=bltp
#SBATCH --partition=bltp
#SBATCH --constraint=cascade
#SBATCH --qos=short

## max. execution time
#SBATCH -t 0-04:00:00

##SBATCH --exclusive

##SBATCH --mem=128GB
##SBATCH --mem=264GB
#SBATCH --mem=36GB

# do not restart in the case of nodefail!
#SBATCH --no-requeue
#SBATCH --no-kill

#SBATCH -N 1 -n 6
##SBATCH --ntasks-per-node=12

##SBATCH  --sockets-per-node=1

## memory NO !!!
##SBATCH --mem-per-cpu=28G

## stdout/stderr output file
##SBATCH -o log_slurm_job.%j.%N.std_out_err
#SBATCH -o log_slurm_job.%j.%N.std_out

## mail
#SBATCH --mail-user=milias@jinr.ru
#SBATCH --mail-type=ALL

echo -e "\nRunning on host `hostname`"
echo -e "Time is `date` \n"
ulimit -s unlimited

echo -e "\n The total memory at the node (in GB)"
free -t -g
echo -e "\n"
 
echo Job user is $SLURM_JOB_USER and his job $SLURM_JOB_NAME has assigned ID $SLURM_JOBID
echo This job was submitted from the computer $SLURM_SUBMIT_HOST
echo and from the home directory:
echo $SLURM_SUBMIT_DIR
echo
echo It is running on the cluster compute node:
echo $SLURM_CLUSTER_NAME
echo and is employing $SLURM_JOB_NUM_NODES node/nodes:
echo $SLURM_JOB_NODELIST
echo
echo -e "Job partition is $SLURM_JOB_PARTITION \n"
echo The job requests $SLURM_CPUS_ON_NODE CPU per task.

# CPU model, total numer of CPUs, number of allocated CPUs
echo -e "The node's CPU \c"; cat /proc/cpuinfo | grep 'model name' | uniq
NPROCS=`cat /proc/cpuinfo | grep processor | wc -l`
echo "This node has total NPROCS=$NPROCS CPUs available for an EXCLUSIVE job."
echo "Based on reserved memory, this node got SLURM_CPUS_ON_NODE=$SLURM_CPUS_ON_NODE CPUs allocated for SLURM calculations."
echo "This job wants SLURM_NTASKS=$SLURM_NTASKS threads . "


#MACHINEFILE="nodes.$SLURM_JOB_PARTITION.$SLURM_JOB_ID"
# Generate Machinefile for mpi such that hosts are in the same
# order as if run via srun
#srun -l /bin/hostname | sort -n | awk '{print $2}' > $MACHINEFILE
echo -e "\n Allocated working nodes:"
srun -l /bin/hostname | sort -n | awk '{print $2}' 
#echo -e "\ngenerated machinefile for MPI, $MACHINEFILE"; ls -lt $PWD/$MACHINEFILE; echo "containing:"; cat $MACHINEFILE

echo -e "\n\n loaded modules:"
module purge
#export MODULEPATH=/cvmfs/nica.jinr.ru/sw/202309/MODULES/slc9_x86-64:$MODULEPATH
#module add autotools

module add Python/v3.12.13
module add CMake/v3.26.5
#module add intel/v2023.1.0
module add intel/v2025.3.1
#module add openmpi/v5.0.3_gcc1230
#module add LAPACK/v3.12.0_gcc1230
module list

#
# IntelMPI compiled OpenMPI
#
INSTALLPATH=/lustre/projects/m/milias/work/software/openmpi/openmpi-5.0.9-intelv2025.3.1
INSTALLDIR=install_openmpi-5.0.9-intelv2025.3.1

prefixdir=$INSTALLPATH/$INSTALLDIR
echo -e "\n Checking presence of full path install dir, ls -lt :"; ls -lt $INSTALLPATH/$INSTALLDIR

echo -e "\n\n  OpenMPI installed binaries and libs:"
ls -lt $prefixdir/bin/*
ls -lt $prefixdir/lib/*

export PATH=$prefixdir/bin:$PATH
export LD_LIBRARY_PATH=$prefixdir/lib:$LD_LIBRARY_PATH


echo -e "\n python ? :\c"; which python; python -V
echo -e "  cmake ? :\c";  which cmake; cmake --version
echo -e "  ifx ? :\c"; which ifx; ifx -V
#echo -e "  mpiifx ? :\c"; which mpiifx; mpiifx -V
echo -e "  mpif90 ? :\c"; which mpif90; mpif90 -V
echo -e "  icx ? :\c"; which icx; icx -V
#echo -e "  mpiicx ? :\c"; which mpiicx; mpiicx -V
echo -e "  mpicc ? :\c"; which mpicc; mpicc -V
echo -e "  icpx ? :\c"; which icpx; icpx  -V
echo -e "  mpicxx ? :\c"; which mpicxx; mpicxx  -V
echo -e "  mpirun ? :\c"; which mpirun; mpirun --version
echo -e "\n Intel MKL library ? MKLROOT=$MKLROOT"; ls -lt  $MKLROOT/lib/intel64

echo -e "\n The variable PATH=$PATH\n"
echo -e "\n The variable LD_LIBRARY_PATH=$LD_LIBRARY_PATH\n"

ELPA_DIR=/lustre/projects/m/milias/work/software/elpa/elpa-2025.01.002
ELPA=$ELPA_DIR/elpa-2025.01.002

#BUILD=build_intel2025.3.1
BUILD=build_openmpi5.0.9-intel2025.3.1
INSTALL_DIR=$ELPA_DIR/install_$BUILD

cd $ELPA_DIR
echo -e "\nI am in the directory ELPA_DIR=$ELPA_DIR; verify via pwd:";pwd
if [ -d "install_$BUILD" ]; then
  echo -e "\nPREVIOUS directory 'install_$BUILD' exists. Removing it.After recreating it again by mkdir."
  rm -rf install_$BUILD
else
  echo -e "\nPREVIOUS directory 'install_$BUILD' does not exist - will be created by mkdir."
fi
mkdir install_$BUILD


cd $ELPA
echo -e "\n I am  in :\c"; pwd

#echo -e "\n\n Going to do autoreconf -f -i :"
#autoreconf -f -i

echo -e "\n Checking configure --help :"
configure --help

echo -e "\n\n Going to do the own configure :"
#./configure --prefix=$INSTALL_DIR  --enable-mpi-module  --enable-ifx-compiler --with-mpi=yes  F77=ifx FC=ifx CXX=icpx CC=icx

#./configure --prefix=$INSTALL_DIR  --enable-mpi-module  --enable-ifx-compiler --with-mpi=yes SCALAPACK_LDFLAGS="-L${MKLROOT}/lib.intel64 -lmkl_scalapack_lp64 -Wl,--start-group -lmkl_intel_lp64 -lmkl_intel_thread -lmkl_core -lmkl_blacs_intelmpi_lp64 -Wl,--end-group -liomp5 -lpthread -lm -ldl"   LDFLAGS="-L$MKLROOT/lib/intel64" FCFLAGS="-I$MKLROOT/include -O3 -xHost" CCFLAGS="-O3 -xHost"  F77=mpiifx FC=mpiifx CXX=mpiicpx CC=mpiicx

#./configure --prefix=$INSTALL_DIR  --enable-mpi-module  --enable-ifx-compiler --with-mpi=yes SCALAPACK_LDFLAGS="-L${MKLROOT}/lib.intel64 -lmkl_scalapack_lp64 -Wl,--start-group -lmkl_intel_lp64 -lmkl_intel_thread -lmkl_core -lmkl_blacs_intelmpi_lp64 -Wl,--end-group -liomp5 -lpthread -lm -ldl"   LDFLAGS="-L$MKLROOT/lib/intel64" FCFLAGS="-I$MKLROOT/include -O3 -xHost" CCFLAGS="-O3 -xHost   -mmmx -msse -msse2 -msse3 -mssse3 -msse4.1 -msse4.2 -maes -mavx -mfma -mavx2 -mavx512f -mavx512cd -mavx512vl -mavx512bw -mavx512dq"  F77=mpiifx FC=mpiifx CXX=mpiicpx CC=mpiicx

# try to fix ... error: Could not compile a test program with AVX
#./configure --prefix=$INSTALL_DIR --disable-avx --disable-avx2 --disable-avx512  --enable-mpi-module  --enable-ifx-compiler --with-mpi=yes SCALAPACK_LDFLAGS="-L${MKLROOT}/lib.intel64 -lmkl_scalapack_lp64 -Wl,--start-group -lmkl_intel_lp64 -lmkl_intel_thread -lmkl_core -lmkl_blacs_intelmpi_lp64 -Wl,--end-group -liomp5 -lpthread -lm -ldl"   LDFLAGS="-L$MKLROOT/lib/intel64" FCFLAGS="-I$MKLROOT/include -O3 -xHost" CCFLAGS="-O3 -xHost"  F77=mpiifx FC=mpiifx CXX=mpiicpx CC=mpiicx

#./configure --prefix=$INSTALL_DIR --enable-mpi-module  --enable-ifx-compiler --with-mpi=yes SCALAPACK_LDFLAGS="-L${MKLROOT}/lib.intel64 -lmkl_scalapack_lp64 -Wl,--start-group -lmkl_intel_lp64 -lmkl_intel_thread -lmkl_core -lmkl_blacs_intelmpi_lp64 -Wl,--end-group -liomp5 -lpthread -lm -ldl"   LDFLAGS="-L$MKLROOT/lib/intel64" FCFLAGS="-I$MKLROOT/include -O3 -xHost" CCFLAGS="-O3 -xHost -msse3"  F77=mpif90 FC=mpif90 CXX=mpicc CC=mpicxx

./configure --prefix=$INSTALL_DIR --disable-sse-kernels  --disable-sse-assembly-kernels --enable-mpi-module  --enable-ifx-compiler --with-mpi=yes SCALAPACK_LDFLAGS="-L${MKLROOT}/lib.intel64 -lmkl_scalapack_lp64 -Wl,--start-group -lmkl_intel_lp64 -lmkl_intel_thread -lmkl_core -lmkl_blacs_intelmpi_lp64 -Wl,--end-group -liomp5 -lpthread -lm -ldl"   LDFLAGS="-L$MKLROOT/lib/intel64" FCFLAGS="-I$MKLROOT/include -O3 -xHost" CCFLAGS="-O3 -xHost -msse3"  F77=mpif90 FC=mpif90 CXX=mpicc CC=mpicxx
 
echo -e "\n\n Going to do make -j $SLURM_CPUS_ON_NODE :"
make -j $SLURM_CPUS_ON_NODE 
echo -e "\n\n Going to do make all install :"
make all install

echo -e "\n after the compilation, check binaries and libraries:"
ls -lt $INSTALL_DIR/bin/*
ls -lt $INSTALL_DIR/lib/*

exit
