#!/bin/bash

#SBATCH -J GMXintel

##  partition (queue)
##  partition (queue)
#SBATCH --account=bltp
#SBATCH --partition=bltp
##SBATCH --constraint=cascade
#SBATCH --constraint=icelake
#SBATCH --qos=medium

## max. execution time
##SBATCH -t 7-00:00:00
#SBATCH -t 0-06:00:00

##SBATCH --exclusive

#SBATCH --mem=32GB
## memory NO !!!
##SBATCH --mem-per-cpu=28G

# do not restart in the case of nodefail!
#SBATCH --no-requeue
#SBATCH --no-kill

#SBATCH -N 1 -n 8
#SBATCH  --sockets-per-node=1

## stdout/stderr output file
##SBATCH -o log_slurm_job.%j.%N.std_out_err
#SBATCH -o log_slurm_job.%j.%N.std_out

## mail
#SBATCH --mail-user=milias@theor.jinr.ru
#SBATCH --mail-type=ALL


echo -e "\n Job user is $SLURM_JOB_USER and his job $SLURM_JOB_NAME has assigned ID $SLURM_JOBID"
echo This job was submitted from the computer $SLURM_SUBMIT_HOST
echo and from the home directory:
echo $SLURM_SUBMIT_DIR
echo
echo It is running on the cluster compute node:
echo $SLURM_CLUSTER_NAME
echo and is employing $SLURM_JOB_NUM_NODES node/nodes:
echo $SLURM_JOB_NODELIST
echo
echo -e "Job partition is $SLURM_JOB_PARTITION \n"
echo The job requests $SLURM_CPUS_ON_NODE CPU per task.

echo -e "\n\n...Loading modules :"
module purge
module load  Python/v3.12.13  
module load  intel/v2026.1.0
module load  CMake/v3.26.5
echo -e "\n...loaded modules :"
module list

# 
  echo -e "\n\n*** hydra.jinr.ru setting for compilation:   ***"

  export GROMACS_ROOT=/lustre/projects/m/milias/work/software/gromacs/git_cloned
  export GROMACS=$GROMACS_ROOT/gromacs
  export REGTESTS=$GROMACS_ROOT/gromacs-regressiontests
  #export BUILD=build_intelmpi2025.3.1_mkl
  export BUILD=build_intelmpi2026.1.0_mkl

  echo -e "\n GROMACS=$GROMACS"
  echo -e "\n GROMACS REGRESSION TESTS=$REGTESTS"

  #echo -e "ifort ?"; which ifort; ifort --version
 # echo -e "clang ?"; which clang; clang --version
 # echo -e "clang++ ?"; which clang++ ; clang++ --version
  echo -e "icx ?"; which icx; icx --version
  echo -e "mpiicpx ?"; which mpiicpx; mpiicpx  --version
 # echo -e "mpiifort ?"; which mpiifort; mpiifort -V
  echo -e "mpirun ?";  which mpirun; mpirun --version
  echo -e "\n ===  We have the MKL library, MKLROOT=${MKLROOT}"


  cd $GROMACS

  if [ -d "$BUILD" ]; then
    echo  -e "\nBuild directory '$BUILD' found, removing it..."
    rm -rf "$BUILD"
  else
    echo -e "\n Previous directory '$BUILD' not found..."
  fi
  mkdir $BUILD
  echo -e "\nEmpty directory '$BUILD' created..."

  cd $BUILD
  echo -e "\n I am in GROMACS/BUILD=$GROMACS/$BUILD:\c";
  echo -e "\n                   pwd=";pwd

# The Intel classic compiler (icc/icpc) is no longer supported in GROMACS. Use Intel’s newer clang-based compiler from oneAPI, or gcc.
  echo -e "\n\n running cmake configuration : "
 # cmake .. -DCMAKE_C_COMPILER=clang -DCMAKE_CXX_COMPILER=clang++  -DGMX_MPI=on  -DGMX_FFT_LIBRARY=mkl  -DGMX_OPENMP=OFF -DREGRESSIONTEST_DOWNLOAD=OFF -DREGRESSIONTEST_PATH=$REGTESTS
  cmake .. -DCMAKE_C_COMPILER=icx -DCMAKE_CXX_COMPILER=mpiicpx  -DGMX_MPI=on  -DGMX_FFT_LIBRARY=mkl  -DGMX_OPENMP=OFF -DREGRESSIONTEST_DOWNLOAD=OFF -DREGRESSIONTEST_PATH=$REGTESTS

  echo -e "\n\n running make -j $SLURM_CPUS_ON_NODE : "
  make -j $SLURM_CPUS_ON_NODE
   
  echo -e "\n\n After, ls -lt bin :"
  ls -lt bin
  echo -e " ldd bin/gmx_mpi :"
  ldd bin/gmx_mpi

  echo -e "\n\n make check :"
  make VERBOSE=1 check

  exit 0
