#!/bin/bash

#SBATCH -J gmx

##  partition (queue)
#SBATCH --account=bltp
#SBATCH --partition=bltp
#SBATCH --constraint=icelake
#SBATCH --qos=medium

## max. execution time
##SBATCH -t 7-00:00:00
#SBATCH -t 1-00:00:00

##SBATCH --exclusive

#SBATCH --mem=32GB
##SBATCH --mem=64GB
##SBATCH --mem=164GB
##SBATCH --mem=16GB

# do not restart in the case of nodefail!
#SBATCH --no-requeue
#SBATCH --no-kill

#SBATCH -N 1 -n 8
#SBATCH  --sockets-per-node=1

## memory NO !!!
##SBATCH --mem-per-cpu=28G

## stdout/stderr output file
##SBATCH -o log_slurm_job.%j.%N.std_out_err
#SBATCH -o log_slurm_job.%j.%N.std_out

## mail
#SBATCH --mail-user=milias@theor.jinr.ru
#SBATCH --mail-type=ALL


echo -e "\n Job user is $SLURM_JOB_USER and his job $SLURM_JOB_NAME has assigned ID $SLURM_JOBID"
echo This job was submitted from the computer $SLURM_SUBMIT_HOST
echo and from the home directory:
echo $SLURM_SUBMIT_DIR
echo
echo It is running on the cluster compute node:
echo $SLURM_CLUSTER_NAME
echo and is employing $SLURM_JOB_NUM_NODES node/nodes:
echo $SLURM_JOB_NODELIST
echo
echo -e "Job partition is $SLURM_JOB_PARTITION \n"
echo The job requests $SLURM_CPUS_ON_NODE CPU per task.

echo -e "\n lsb_release -a :"; lsb_release -a


#echo "modules at disposal:"
#module avail
#echo
#
module purge
#module load openmpi/v2.1.2-2
#module add GVR/v1.0-1
#module add Python/v3.10.13
module add  Python/v3.12.13  

#module add openmpi/v5.0.7_gcc1230
module add   openmpi/v5.0.9_gcc1230 

#module add fftw/v3.3.10_gcc1120
#module add fftw/v3.3.10_openmpi503
module add fftw/v3.3.10_openmpi418

#module add LAPACK/v3.12.0_gcc1230
module add LAPACK/v3.12.0_gcc1230

#module add CMake/v3.29.2

echo -e "\n\n loaded modules :"
module list

# 
  echo -e "\n\n*** hydra.jinr.ru setting for compilation:   ***"

  export GROMACS=/zfs/scratch/HybriLITWorkshop2025/milias/software/gromacs/git_cloned/gromacs
  export REGTESTS=/zfs/scratch/HybriLITWorkshop2025/milias/software/gromacs/git_cloned/gromacs-regressiontests
  #export BUILD=build_openmpi
  export BUILD=build_openmpi_gnu

  echo -e "\n\n GROMACS=$GROMACS"
  #echo -e "\n GROMACS REGRESSION TESTS=$REGTESTS"
  #echo -e "gcc ?"; which gcc; gcc --version
  echo -e "g++ ?"; which g++; g++ --version
  echo -e "mpicxx ?"; which mpicxx; mpicxx --version
  echo -e "mpirun ?";  which mpirun; mpirun --version
  #echo -e "\n ===  We have the MKL library, MKLROOT=${MKLROOT}"

  GMX_PATH=$GROMACS/$BUILD/bin

  echo -e "\n\n Looking after $GMX_PATH/gmx_mpi  :"; ls -lt $GMX_PATH/gmx_mpi
  ldd $GMX_PATH/gmx_mpi

  echo -e "\n\n just poking executable:"
  $GMX_PATH/gmx_mpi 

  $GMX_PATH/gmx_mpi help commands

  $GMX_PATH/gmx_mpi help selections

  $GMX_PATH/gmx_mpi help selections examples
   
  exit 0
