; minim.mdp - with reduced cutoff for small box
integrator               = steep
emtol                    = 1000.0
emstep                   = 0.01
nsteps                   = 50000

nstlist                  = 1
cutoff-scheme            = Verlet
ns_type                  = grid
coulombtype              = PME
rcoulomb                 = 0.8          ; Reduced from 1.0 to 0.8
rvdw                     = 0.8          ; Reduced from 1.0 to 0.8
rlist                    = 0.8          ; Added to match
pbc                      = xyz
