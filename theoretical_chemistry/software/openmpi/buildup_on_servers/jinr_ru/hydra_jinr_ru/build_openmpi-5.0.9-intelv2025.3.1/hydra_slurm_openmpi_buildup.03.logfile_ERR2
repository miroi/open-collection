  --with-memory-manager=TYPE
                          Use TYPE for intercepting memory management calls to
                          control memory pinning.
  --with-memkind(=DIR)    ,
		Build with MEMKIND, searching for headers in DIR)
  --with-udreg            Build support for Cray udreg support. Set
