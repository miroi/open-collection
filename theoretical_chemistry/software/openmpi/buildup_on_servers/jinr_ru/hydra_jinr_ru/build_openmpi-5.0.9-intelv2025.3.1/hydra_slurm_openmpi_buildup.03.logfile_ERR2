  --with-pmix-extra-libs=LIBS
                          Add LIBS as dependencies of pmix
  --with-pbs              Build PBS scheduler component (default: yes)
  --with-libfabric=DIR    Deprecated synonym for --with-ofi
  --with-libfabric-libdir=DIR
