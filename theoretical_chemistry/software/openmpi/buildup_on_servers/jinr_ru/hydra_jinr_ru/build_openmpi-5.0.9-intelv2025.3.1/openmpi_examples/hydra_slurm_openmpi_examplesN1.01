#!/bin/bash

#SBATCH -J OMPIex

#!/bin/bash
#SBATCH -A bltp
#SBATCH -p bltp
#SBATCH -C icelake
#SBATCH -q medium

## max. execution time
#SBATCH -t 0-04:00:00

##SBATCH --exclusive

##SBATCH --mem=128GB
##SBATCH --mem=264GB
#SBATCH --mem=24GB

# do not restart in the case of nodefail!
#SBATCH --no-requeue
#SBATCH --no-kill

#SBATCH -N 1
#SBATCH --ntasks=4
##SBATCH --ntasks-per-node=12
#SBATCH --cpus-per-task=1

##SBATCH  --sockets-per-node=1

## memory NO !!!
##SBATCH --mem-per-cpu=28G

## stdout/stderr output file
##SBATCH -o log_slurm_job.%j.%N.std_out_err
#SBATCH -o log_slurm_job.%j.%N.std_out

## mail
#SBATCH --mail-user=milias@jinr.ru
#SBATCH --mail-type=ALL

echo -e "\nRunning on host `hostname`"
echo -e "Time is `date` \n"
ulimit -s unlimited

echo -e "\n The total memory at the node (in GB)"
free -t -g
echo -e "\n"
 
echo Job user is $SLURM_JOB_USER and his job $SLURM_JOB_NAME has assigned ID $SLURM_JOBID
echo This job was submitted from the computer $SLURM_SUBMIT_HOST
echo and from the home directory:
echo $SLURM_SUBMIT_DIR
echo
echo It is running on the cluster compute node:
echo $SLURM_CLUSTER_NAME
echo and is employing $SLURM_JOB_NUM_NODES node/nodes:
echo $SLURM_JOB_NODELIST
echo
echo -e "Job partition is $SLURM_JOB_PARTITION \n"
echo The job requests $SLURM_CPUS_ON_NODE CPU per task.

# CPU model, total numer of CPUs, number of allocated CPUs
echo -e "The node's CPU \c"; cat /proc/cpuinfo | grep 'model name' | uniq
NPROCS=`cat /proc/cpuinfo | grep processor | wc -l`
echo "This node has total NPROCS=$NPROCS CPUs available for an EXCLUSIVE job."
echo "Based on reserved memory, this node got SLURM_CPUS_ON_NODE=$SLURM_CPUS_ON_NODE CPUs allocated for SLURM calculations."
echo "This job wants SLURM_NTASKS=$SLURM_NTASKS threads . "

MACHINEFILE="nodes.$SLURM_JOB_PARTITION.$SLURM_JOB_ID"
# Generate Machinefile for mpi such that hosts are in the same
# order as if run via srun
srun -l /bin/hostname | sort -n | awk '{print $2}' > $MACHINEFILE
echo -e "\n Allocated working nodes:"
srun -l /bin/hostname | sort -n | awk '{print $2}' 
echo -e "\ngenerated machinefile for MPI, $MACHINEFILE"; ls -lt $PWD/$MACHINEFILE; echo "containing:"; cat $MACHINEFILE

echo -e "\n\n loaded modules:"
module purge
module add  Python/v3.12.13
module add  intel/v2025.3.1
module list

OMPI=/lustre/projects/m/milias/work/software/openmpi/openmpi-5.0.9-intelv2025.3.1/openmpi-5.0.9
INSTALLPATH=/lustre/projects/m/milias/work/software/openmpi/openmpi-5.0.9-intelv2025.3.1
INSTALLDIR=install_openmpi5.0.9-intel2025.3.1_c
prefixdir=$INSTALLPATH/$INSTALLDIR
echo -e "\n Checking presence of full path install dir, ls -lt :"; ls -lt $INSTALLPATH/$INSTALLDIR

cd $OMPI
echo -e "\n\n I am in directory OMPI=$OMPI"
echo -e "            checking with pwd=\c"; pwd
echo -e "\n Checking configure --help :"; configure --help

echo -e "\n\n Check OpenMPI binaries and libs in $prefixdir/:"
ls -lt $prefixdir/bin/*
ls -lt $prefixdir/lib/*

## make path
export PATH=$prefixdir/bin:$PATH
export LD_LIBRARY_PATH=$prefixdir/lib:$LD_LIBRARY_PATH
echo -e "\n\n updated PATH=$PATH"
echo -e " updated LD_LIBRARY_PATH=$LD_LIBRARY_PATH"

echo -e "\n\n mpif90 ? \c"; which mpif90; mpif90 --version
echo -e "  ifx ? :\c"; which ifx; ifx -V
echo -e "\n\n mpicc ? \c";  which mpicc; mpicc --version
echo -e "  icx ? :\c"; which icx; icx -V
echo -e "\n\n mpicxx ? \c"; which mpicxx; mpicxx --version
echo -e "  icpx ? :\c"; which icpx; icpx  -V
echo -e "\n Intel MKL library ? MKLROOT=$MKLROOT"; ls -lt  $MKLROOT/lib/intel64

echo -e "\n\n mpirun ? \c"; which mpirun; mpirun --version; mpirun --help
echo -e "\n\n ompi_info ? \c"; which ompi_info; ompi_info -all

echo -e "\n\n Examples in $OMPI/examples :"; ls -lt $OMPI/examples/. 

ldd $OMPI/examples/hello_c
ldd $OMPI/examples/ring_usempi
ldd $OMPI/examples/ring_mpifh
ldd $OMPI/examples/spc_example

mpirun  --hostfile $MACHINEFILE  -np $SLURM_NTASKS $OMPI/examples/hello_c
mpirun  --hostfile $MACHINEFILE  -np $SLURM_NTASKS $OMPI/examples/connectivity_c
mpirun  --hostfile $MACHINEFILE -np $SLURM_NTASKS $OMPI/examples/hello_sessions_c
mpirun  --hostfile $MACHINEFILE  -np $SLURM_NTASKS $OMPI/examples/hello_usempi
mpirun  --hostfile $MACHINEFILE  -np $SLURM_NTASKS $OMPI/examples/ring_c
mpirun  --hostfile $MACHINEFILE  -np $SLURM_NTASKS $OMPI/examples/ring_mpifh
mpirun  --hostfile $MACHINEFILE  -np $SLURM_NTASKS $OMPI/examples/ring_usempi
mpirun  --hostfile $MACHINEFILE   -np $SLURM_NTASKS $OMPI/examples/spc_example


exit
