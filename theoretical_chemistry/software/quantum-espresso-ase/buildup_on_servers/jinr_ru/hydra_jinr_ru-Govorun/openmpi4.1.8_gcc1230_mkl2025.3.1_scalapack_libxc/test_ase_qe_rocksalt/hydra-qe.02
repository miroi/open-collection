#!/bin/bash

## jobname
#SBATCH -J nacl

##  partition (queue)
#SBATCH --account=bltp
#SBATCH --partition=bltp
#SBATCH --constraint=icelake
##SBATCH --constraint=cascade

#SBATCH --qos=short

## max. execution time
##SBATCH -t 4-00:00:00
#SBATCH -t 0-03:00:00
##SBATCH -t 30-00:00:00

##SBATCH --exclusive

##SBATCH --mem=640GB
##SBATCH --mem=30GB
##SBATCH --mem=16GB

##SBATCH --mem-per-cpu=2GB
#SBATCH --mem=16GB

## do not restart in the case of nodefail!
##SBATCH --no-requeue
##SBATCH --no-kill

## nodes
#SBATCH --nodes=2
#SBATCH --ntasks-per-node=4
#SBATCH --cpus-per-task=1
#SBATCH --distribution=block:block,nopack

## stdout/stderr output file
#SBATCH -o log_slurm_job.%j.%N.std_out_err

## E-mail
#SBATCH --mail-user=milias@theor.jinr.ru
#SBATCH --mail-type=ALL

#### modules  ####
module purge
module load  Python/v3.12.13
module load  intel/v2025.3.1
module load  openmpi/v4.1.8_gcc1230
echo -e "\n\n loaded modules:"
module list


#### QE ####
QE_DIR=/lustre/projects/m/milias/work/software/quantum-espresso/git_cloned/q-e
#BUILD=build_openmpi4.1.8_gcc12.3.0_LAPACK3.12.0_fftw3.3.10_libxc
BUILD=build_openmpi4.1.8_gcc12.3.0_libcx_mkl2025.3.1_scalapack
export QE=$QE_DIR/$BUILD

echo -e "\nldd  $QE/bin/pw.x :"
ldd  $QE/bin/pw.x


##--------------------------------------------------------------------------------------------------------------
##
##
##-------------------------------------------Print debug info---------------------------------------------------
echo -e "\nRunning on host `hostname`"
echo -e "Time is `date` \n"

echo -e "\n The total memory at the node (in GB)"
free -t -g
echo -e "\n"

echo -e "\nJob user is SLURM_JOB_USER= $SLURM_JOB_USER"
echo -e "User job SLURM_JOB_NAME=$SLURM_JOB_NAME has assigned ID SLURM_JOBID=$SLURM_JOBID"
echo -e "This job was submitted from the computer SLURM_SUBMIT_HOST=$SLURM_SUBMIT_HOST"
echo -e "and from the home directory SLURM_SUBMIT_DIR:"
echo -e "$SLURM_SUBMIT_DIR"

echo -e "Job is running on the cluster compute node: SLURM_CLUSTER_NAME=$SLURM_CLUSTER_NAME"
echo -e "and is employing SLURM_JOB_NUM_NODES=$SLURM_JOB_NUM_NODES node/nodes:"
echo -e "SLURM_JOB_NODELIST = $SLURM_JOB_NODELIST"
echo -e "Job partition is SLURM_JOB_PARTITION=$SLURM_JOB_PARTITION \n"
echo -e "Number of allocated CPUs on each single node, SLURM_CPUS_ON_NODE=$SLURM_CPUS_ON_NODE ."
echo -e "Number of all reserved threads over ALL nodes, SLURM_NTASKS=$SLURM_NTASKS ."
echo -e "Job has reserved memory per node, SLURM_MEM_PER_NODE=$SLURM_MEM_PER_NODE MB of memory"


MACHINEFILE="nodes.$SLURM_JOB_PARTITION.$SLURM_JOB_ID"
# Generate Machinefile for mpi such that hosts are in the same
# order as if run via srun
srun -l /bin/hostname | sort -n | awk '{print $2}' > $MACHINEFILE
echo -e "\ngenerated machinefile for MPI, $MACHINEFILE"; ls -lt $PWD/$MACHINEFILE; echo "containing:"; cat $MACHINEFILE


# CPU model, total numer of CPUs, number of allocated CPUs
echo -e "The node's CPU \c"; cat /proc/cpuinfo | grep 'model name' | uniq
NPROCS=`cat /proc/cpuinfo | grep processor | wc -l`
echo "BTW, this node has total $NPROCS CPUs available for an EXCLUSIVE job."
echo "Based on reserved memory, this node got $SLURM_CPUS_ON_NODE CPUs allocated for SLURM calculations."
echo "This job wants SLURM_NTASKS=$SLURM_NTASKS threads . "

echo -e "\n\n SLURM version: "
sinfo -V
scontrol version
sacct --version

echo -e "\n\n Check nodes on the hyperthreading :"
#
grep -m 1 "flags" /proc/cpuinfo | grep -o "ht"
#
sinfo -Node -o "%N %.5D %.9P %11T %.4c %.4X %.4Y %.4Z"
# Prints: NodeName, Sockets, Cores, Threads
sinfo -n $SLURMD_NODENAME -o "%N %X %Y %Z"
#
scontrol show job $SLURM_JOB_ID | grep -E "ThreadsPerCore|TresPerNode"


## get venv
#echo -e "\n\n Activating Python virtual environment: source /lustre/projects/m/milias/work/software/myvenv/bin/activate "
#source /lustre/projects/m/milias/work/software/myvenv/bin/activate
#pip show ase

echo -e "\n\n My PATH=$PATH\n"
echo -e "\n My LD_LIBRARY_PATH=$LD_LIBRARY_PATH "

echo -e "Python ? :\c"; which python; python -V
echo -e "\n mpif90 ?: \c"; which mpif90; mpif90 -V
echo -e "\n mpirun ? \c"; which mpirun; mpirun --version; mpirun --help
echo -e "\n ompi_info ?"; which ompi_info; ompi_info -V

# for running jobs from your homedir, use ...
cd $SLURM_SUBMIT_DIR

echo -e "\n Current directory where this SLURM job is running `pwd`"
echo " It has the disk space of (df -h) :"
df -h .
echo

export OMP_NUM_THREADS=1

#
# own QE job
#
project=NaCl_qe
inp=$project.in
out=$project.$SLURM_CLUSTER_NAME.$SLURM_JOB_PARTITION.N$SLURM_JOB_NUM_NODES.n$SLURM_NTASKS.jid$SLURM_JOBID.out
echo -e "\n Running QE pw.x with Intel2025-OpenMPI5 parallel job:"
#  OpenMPI : #
#export OMPI_MCA_btl=^openib

#mpirun -v -np $SLURM_NTASKS --hostfile $MACHINEFILE --bind-to core:overload-allowed  $qe_bin/bin/pw.x -npool $SLURM_JOB_NUM_NODES  < $inp > $out
#mpirun -v -np $SLURM_NTASKS --hostfile $MACHINEFILE  --bind-to core:overload-allowed  $qe_bin/bin/pw.x  < $inp > $out
#mpirun -v -np $SLURM_NTASKS --hostfile $MACHINEFILE  --map-by core:OVERSUBSCRIBE --bind-to core:overload-allowed  $qe_bin/bin/pw.x  < $inp > $out
#mpirun -v -np $SLURM_NTASKS --hostfile $MACHINEFILE  --oversubscribe --mca pml ob1 --mca btl tcp,self  $qe_bin/bin/pw.x  < $inp > $out
#mpirun -v -np $SLURM_NTASKS --hostfile $MACHINEFILE  --oversubscribe --bind-to none  $qe_bin/bin/pw.x  -input  $inp > $out
#mpirun -v -np $SLURM_NTASKS --hostfile $MACHINEFILE --bind-to core:overload-allowed  $qe_bin/bin/pw.x  -npool $SLURM_JOB_NUM_NODES  -input  $inp > $out
#MPIRUN_DIR=/lustre/projects/m/milias/work/software/openmpi/openmpi-5.0.9-intelv2025.3.1/install_openmpi-5.0.9-intelv2025.3.1/bin
#$MPIRUN_DIR/mpirun -v -np $SLURM_NTASKS --hostfile $MACHINEFILE --bind-to core:overload-allowed  $qe_bin/bin/pw.x  -npool $SLURM_JOB_NUM_NODES  -input  $inp > $out
#$MPIRUN_DIR/mpirun -v -np $SLURM_NTASKS --hostfile $MACHINEFILE --bind-to none  $qe_bin/bin/pw.x  -npool $SLURM_JOB_NUM_NODES  -input  $inp > $out
#$MPIRUN_DIR/mpirun -v -np $SLURM_NTASKS --hostfile $MACHINEFILE --bind-to none  $qe_bin/bin/pw.x   -input  $inp > $out
#$MPIRUN_DIR/mpirun  -v -np $SLURM_NTASKS --hostfile $MACHINEFILE --bind-to hwthread  $qe_bin/bin/pw.x   -input  $inp > $out

#mpirun  -v  --hostfile $MACHINEFILE   -np $SLURM_NTASKS  $QE/bin/pw.x   -npool $SLURM_JOB_NUM_NODES    -input  $inp > $out
mpirun  -v  --hostfile $MACHINEFILE --use-hwthread-cpus --report-bindings    -np $SLURM_NTASKS  $QE/bin/pw.x    -input  $inp > $out

echo -e "\n\n QE finished on : \c";date

exit

