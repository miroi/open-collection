&CONTROL
   verbosity        = 'low'
   tstress          = .true.
   tprnfor          = .true.
   outdir           = './tmp'
   prefix           = 'NaCl'
   disk_io          = 'minimal'
   pseudo_dir       = './'
/
&SYSTEM
   ibrav            = 0
   nat              = 8
   ntyp             = 2
   ecutwfc          = 90
   occupations      = 'smearing'
   degauss          = 0.01
   smearing         = 'gauss'
   input_dft        = 'XC-000I-000I-116L-133L-000I-000I'
/
&ELECTRONS
   electron_maxstep = 100
   conv_thr         = 1e-09
   mixing_beta      = 0.2
   diagonalization  = 'david'
   diago_full_acc   = .true.
   startingpot      = 'atomic'
   startingwfc      = 'atomic+random'
/
&IONS
/
&CELL
/
&FCP
/
&RISM
/
ATOMIC_SPECIES
Na 22.98976928 Na.upf
Cl 35.45 Cl.upf

K_POINTS automatic
2 2 2  0 0 0

